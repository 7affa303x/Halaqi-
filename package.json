{
  "name": "halaqi",
  "version": "1.0.0",
  "private": true,
  "description": "Halaqi - Barbershop Management System",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:generate": "pnpm --filter backend db:generate",
    "db:seed": "pnpm --filter backend db:seed",
    "db:studio": "pnpm --filter backend db:studio",
    "backend:dev": "pnpm --filter backend dev",
    "web:dev": "pnpm --filter web dev",
    "mobile:dev": "pnpm --filter mobile dev",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
"packageManager": "pnpm@9.15.0",
"engines": {
  "node": ">=20.0.0",
  "pnpm": ">=9.0.0"
}
  }
}
